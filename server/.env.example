# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000
# Public base URL of THIS API, including the API prefix. Used for email tracking
# links and the Gmail OAuth redirect URI. Must be reachable by Google in prod.
#   dev:  http://localhost:5000/api/v1
#   prod: https://<your-api-domain>/api/v1
API_PUBLIC_URL=http://localhost:5000/api/v1

# ─── Database ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/hiresense
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── AI ───────────────────────────────────────────────────
# You need EITHER an Anthropic key here, OR an OpenAI key below, OR a provider
# registered in the admin panel (Dashboard → AI Providers). Any one is enough.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
AI_MODEL=claude-opus-4-8
AI_MODEL_FAST=claude-haiku-4-5-20251001
AI_MAX_TOKENS=4096

# OpenAI, configured straight from the environment. Leave blank to manage
# providers in the admin panel instead.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Only set for Azure/proxies/compatible gateways; blank uses api.openai.com.
OPENAI_BASE_URL=

# Encrypts AI provider API keys at rest (defaults to JWT secret if unset; set a stable value in prod)
AI_ENCRYPTION_KEY=

# ─── Voice / TTS (Sarvam AI — natural Indian Hindi/English voices) ──
# Get a key at https://dashboard.sarvam.ai — leave blank to use browser TTS.
SARVAM_API_KEY=
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_SPEAKER_FEMALE=anushka
SARVAM_SPEAKER_MALE=abhilash

# ─── Email (SMTP) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="HireSense <no-reply@hiresense.ai>"

# ─── OAuth (Google login + per-company Gmail sending) ─────
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (type: Web application).
# Add this Authorized redirect URI (must equal API_PUBLIC_URL + the path below):
#   ${API_PUBLIC_URL}/integrations/gmail/callback
#   e.g. https://<your-api-domain>/api/v1/integrations/gmail/callback
# Enable the "Gmail API" and add scopes: gmail.send, userinfo.email, openid.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Payments ─────────────────────────────────────────────
# Invoice GST defaults (admin Settings → Invoices & GST overrides these without
# a deploy). GST lines appear on invoices only when a GSTIN is set; prices are
# GST-inclusive, so enabling this never changes what customers are charged.
GST_NUMBER=
GST_PERCENT=18
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Cashfree (CASHFREE_ENV: sandbox | production)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
CASHFREE_WEBHOOK_SECRET=

# ─── SMS / WhatsApp (Twilio) ──────────────────────────────
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP_FROM=

# ─── Misc ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
BCRYPT_ROUNDS=12
