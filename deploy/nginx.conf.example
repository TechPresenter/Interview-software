# HireSense reverse proxy.
# 1) Replace YOUR_DOMAIN below with your real domain (both places).
# 2) Save to /etc/nginx/sites-available/hiresense
# 3) ln -s /etc/nginx/sites-available/hiresense /etc/nginx/sites-enabled/
#    rm -f /etc/nginx/sites-enabled/default
#    nginx -t && systemctl reload nginx
# 4) Enable HTTPS:  certbot --nginx -d YOUR_DOMAIN -d www.YOUR_DOMAIN

server {
    listen 80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    # allow large uploads (knowledge-base files, interview recordings)
    client_max_body_size 120M;

    # Express API (mounted at /api/v1) + email tracking + uploads
    location /api/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /uploads/ {
        proxy_pass http://127.0.0.1:5000;
    }

    # Socket.IO (realtime)
    location /socket.io/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
    }

    # Next.js frontend (everything else)
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
